# ─── Required ─────────────────────────────────────────────────────────────────
# Full base URL of the Gpay-Remit backend API, including the version prefix.
# Must be a valid http or https URL. In production this must be set explicitly;
# in development it falls back to http://localhost:8080/api/v1 with a warning.
REACT_APP_API_URL=http://localhost:8080/api/v1

# ─── Optional ─────────────────────────────────────────────────────────────────
# Stellar network to connect to. Use "testnet" for development/staging and
# "mainnet" for production. Defaults to "testnet" if not set.
REACT_APP_STELLAR_NETWORK=testnet
