PORT=8080
DATABASE_URL=postgres://gpay:gpay_password@localhost:5432/gpay_remit?sslmode=disable

# Stellar Network Configuration
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Smart Contract IDs (populated by deployment script)
CONTRACT_ID=
ESCROW_CONTRACT_ID=
KYC_ORACLE_ID=
AML_ORACLE_ID=
PRICE_ORACLE_ID=

# Fees (basis points)
PLATFORM_FEE_BPS=50
FOREX_FEE_BPS=25
COMPLIANCE_FEE_BPS=10
NETWORK_FEE_BPS=15
MIN_FEE=0
MAX_FEE=0

# Database Connection Pool
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME_MIN=60
# Email Configuration
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@gpay-remit.com

# Redis Configuration
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
